  "methods": [
    {
      "name": "countByProductId",
      "signature": "public abstract java.lang.Long com.grownited.repository.ProductImageRepository.countByProductId(java.lang.Integer)",
      "query": {
        "query": "SELECT COUNT(p) FROM ProductImageEntity p WHERE p.productId = :productId"
      }
    },
    {
      "name": "deleteByProductId",
      "signature": "public abstract void com.grownited.repository.ProductImageRepository.deleteByProductId(java.lang.Integer)",
      "query": {
        "query": "SELECT p FROM ProductImageEntity p WHERE p.productId = :productId"
      }
    },
    {
      "name": "existsByProductId",
      "signature": "public abstract boolean com.grownited.repository.ProductImageRepository.existsByProductId(java.lang.Integer)",
      "query": {
        "query": "SELECT p.productImageId productImageId FROM ProductImageEntity p WHERE p.productId = :productId"
      }
    },
    {
      "name": "findByProductIdAndIsPrimaryTrue",
      "signature": "public abstract java.util.Optional<com.grownited.entity.ProductImageEntity> com.grownited.repository.ProductImageRepository.findByProductIdAndIsPrimaryTrue(java.lang.Integer)",
      "query": {
        "query": "SELECT p FROM ProductImageEntity p WHERE p.productId = :productId AND p.isPrimary = TRUE"
      }
    },
    {
      "name": "findByProductIdOrderByDisplayOrderAsc",
      "signature": "public abstract java.util.List<com.grownited.entity.ProductImageEntity> com.grownited.repository.ProductImageRepository.findByProductIdOrderByDisplayOrderAsc(java.lang.Integer)",
      "query": {
        "query": "SELECT p FROM ProductImageEntity p WHERE p.productId = :productId ORDER BY p.displayOrder asc"
      }
    },
    {
      "name": "findGalleryImagesByProductId",
      "signature": "public abstract java.util.List<com.grownited.entity.ProductImageEntity> com.grownited.repository.ProductImageRepository.findGalleryImagesByProductId(java.lang.Integer)",
      "query": {
        "query": "SELECT p FROM ProductImageEntity p WHERE p.productId = :productId AND p.isPrimary = false ORDER BY p.displayOrder ASC"
      }
    },
    {
      "name": "getMaxDisplayOrder",
      "signature": "public abstract java.lang.Integer com.grownited.repository.ProductImageRepository.getMaxDisplayOrder(java.lang.Integer)",
      "query": {
        "query": "SELECT COALESCE(MAX(p.displayOrder), 0) FROM ProductImageEntity p WHERE p.productId = :productId"
      }
    },
    {
      "name": "resetPrimaryForProduct",
      "signature": "public abstract void com.grownited.repository.ProductImageRepository.resetPrimaryForProduct(java.lang.Integer)",
      "query": {
        "query": "UPDATE ProductImageEntity p SET p.isPrimary = false WHERE p.productId = :productId"
      }
    },
