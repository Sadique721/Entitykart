      "signature": "public abstract java.lang.Long com.grownited.repository.WishlistRepository.countByCustomerId(java.lang.Integer)",
      "query": {
        "query": "SELECT COUNT(w) FROM WishlistEntity w WHERE w.customerId = :customerId"
      }
    },
    {
      "name": "countUsersWithWishlist",
      "signature": "public abstract java.lang.Long com.grownited.repository.WishlistRepository.countUsersWithWishlist()",
      "query": {
