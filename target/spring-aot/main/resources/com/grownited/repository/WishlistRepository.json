    {
      "name": "findByCustomerIdOrderByAddedAtDesc",
      "signature": "public abstract org.springframework.data.domain.Page<com.grownited.entity.WishlistEntity> com.grownited.repository.WishlistRepository.findByCustomerIdOrderByAddedAtDesc(java.lang.Integer,org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT w FROM WishlistEntity w WHERE w.customerId = :customerId ORDER BY w.addedAt desc",
        "count-query": "SELECT COUNT(w) FROM WishlistEntity w WHERE w.customerId = :customerId"
      }
    },
    {
      "name": "findWishlistWithProductDetails",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.WishlistRepository.findWishlistWithProductDetails(java.lang.Integer)",
      "query": {
        "query": "SELECT w, p.productName, CAST(p.price AS float), p.mainImageURL, p.stockQuantity FROM WishlistEntity w JOIN ProductEntity p ON w.productId = p.productId WHERE w.customerId = :customerId ORDER BY w.addedAt DESC"
      }
    },
    {
      "name": "findWishlistWithProductDetails",
      "signature": "public abstract org.springframework.data.domain.Page<java.lang.Object[]> com.grownited.repository.WishlistRepository.findWishlistWithProductDetails(java.lang.Integer,org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT w, p.productName, CAST(p.price AS float), p.mainImageURL, p.stockQuantity FROM WishlistEntity w JOIN ProductEntity p ON w.productId = p.productId WHERE w.customerId = :customerId ORDER BY w.addedAt DESC",
        "count-query": "SELECT count(w) FROM WishlistEntity w JOIN ProductEntity p ON w.productId = p.productId WHERE w.customerId = :customerId"
      }
    },
    {
      "name": "findWishlistedProductIds",
      "signature": "public abstract java.util.List<java.lang.Integer> com.grownited.repository.WishlistRepository.findWishlistedProductIds(java.lang.Integer,java.util.List<java.lang.Integer>)",
      "query": {
        "query": "SELECT w.productId FROM WishlistEntity w WHERE w.customerId = :customerId AND w.productId IN :productIds"
      }
    },
    {
      "name": "getAverageWishlistSize",
      "signature": "public abstract java.lang.Double com.grownited.repository.WishlistRepository.getAverageWishlistSize()",
      "query": {
        "query": "SELECT AVG(wcount) FROM (SELECT COUNT(w) as wcount FROM WishlistEntity w GROUP BY w.customerId)"
      }
    },
    {
      "name": "getMostWishlistedProducts",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.WishlistRepository.getMostWishlistedProducts(org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT w.productId, COUNT(w) as wishlistCount FROM WishlistEntity w GROUP BY w.productId ORDER BY wishlistCount DESC"
      }
    },
    {
      "name": "getWishlistCountsForProducts",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.WishlistRepository.getWishlistCountsForProducts(java.util.List<java.lang.Integer>)",
      "query": {
        "query": "SELECT w.productId, COUNT(w) FROM WishlistEntity w WHERE w.productId IN :productIds GROUP BY w.productId"
      }
    },
