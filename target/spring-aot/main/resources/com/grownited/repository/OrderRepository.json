    },
    {
      "name": "findByPaymentStatus",
      "signature": "public abstract java.util.List<com.grownited.entity.OrderEntity> com.grownited.repository.OrderRepository.findByPaymentStatus(com.grownited.entity.OrderEntity$PaymentStatus)",
      "query": {
        "query": "SELECT o FROM OrderEntity o WHERE o.paymentStatus = :paymentStatus"
      }
    },
    {
      "name": "findTop10ByOrderByOrderDateDesc",
      "signature": "public abstract java.util.List<com.grownited.entity.OrderEntity> com.grownited.repository.OrderRepository.findTop10ByOrderByOrderDateDesc()",
      "query": {
        "query": "SELECT o FROM OrderEntity o ORDER BY o.orderDate desc"
      }
    },
    {
      "name": "getTotalRevenue",
      "signature": "public abstract java.lang.Double com.grownited.repository.OrderRepository.getTotalRevenue()",
      "query": {
        "query": "SELECT COALESCE(SUM(o.totalAmount), 0) FROM OrderEntity o WHERE o.paymentStatus = 'PAID'"
      }
