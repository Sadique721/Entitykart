    {
      "name": "countByOrderStatus",
      "signature": "public abstract java.lang.Long com.grownited.repository.OrderRepository.countByOrderStatus(com.grownited.entity.OrderEntity$OrderStatus)",
      "query": {
        "query": "SELECT COUNT(o) FROM OrderEntity o WHERE o.orderStatus = :status"
      }
    },
    {
      "name": "existsByCustomerId",
      "signature": "public abstract boolean com.grownited.repository.OrderRepository.existsByCustomerId(java.lang.Integer)",
      "query": {
        "query": "SELECT o.orderId orderId FROM OrderEntity o WHERE o.customerId = :customerId"
      }
    },
    {
      "name": "findByCustomerId",
      "signature": "public abstract java.util.List<com.grownited.entity.OrderEntity> com.grownited.repository.OrderRepository.findByCustomerId(java.lang.Integer)",
      "query": {
        "query": "SELECT o FROM OrderEntity o WHERE o.customerId = :customerId"
      }
    },
    {
      "name": "findByCustomerIdAndOrderStatus",
      "signature": "public abstract java.util.List<com.grownited.entity.OrderEntity> com.grownited.repository.OrderRepository.findByCustomerIdAndOrderStatus(java.lang.Integer,com.grownited.entity.OrderEntity$OrderStatus)",
      "query": {
        "query": "SELECT o FROM OrderEntity o WHERE o.customerId = :customerId AND o.orderStatus = :status"
      }
    },
    {
      "name": "findByCustomerIdOrderByOrderDateDesc",
      "signature": "public abstract java.util.List<com.grownited.entity.OrderEntity> com.grownited.repository.OrderRepository.findByCustomerIdOrderByOrderDateDesc(java.lang.Integer)",
      "query": {
        "query": "SELECT o FROM OrderEntity o WHERE o.customerId = :customerId ORDER BY o.orderDate desc"
      }
    },
    {
      "name": "findByOrderStatus",
      "signature": "public abstract java.util.List<com.grownited.entity.OrderEntity> com.grownited.repository.OrderRepository.findByOrderStatus(com.grownited.entity.OrderEntity$OrderStatus)",
      "query": {
