    {
      "name": "findDistinctBrandsByCategory",
      "signature": "public abstract java.util.List<java.lang.String> com.grownited.repository.ProductRepository.findDistinctBrandsByCategory(java.lang.Integer)",
      "query": {
        "query": "SELECT DISTINCT p.brand FROM ProductEntity p WHERE p.brand IS NOT NULL AND (:categoryId IS NULL OR p.categoryId = :categoryId)"
      }
    },
    {
      "name": "findFeaturedProducts",
      "signature": "public abstract org.springframework.data.domain.Page<com.grownited.entity.ProductEntity> com.grownited.repository.ProductRepository.findFeaturedProducts(org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT p.* FROM product p LEFT JOIN order_details od ON p.product_id = od.product_id GROUP BY p.product_id ORDER BY COUNT(od.order_item_id) DESC, p.created_at DESC",
        "count-query": "select count(p.*) FROM product p LEFT JOIN order_details od ON p.product_id = od.product_id GROUP BY p.product_id"
      }
    },
    {
      "name": "findFrequentlyBoughtTogether",
      "signature": "public abstract org.springframework.data.domain.Page<com.grownited.entity.ProductEntity> com.grownited.repository.ProductRepository.findFrequentlyBoughtTogether(java.lang.Integer,org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT p.* FROM product p JOIN order_details od ON p.product_id = od.product_id WHERE od.order_id IN (   SELECT DISTINCT order_id FROM order_details WHERE product_id = :productId) AND p.product_id != :productId GROUP BY p.product_id ORDER BY COUNT(*) DESC",
        "count-query": "select count(p.*) FROM product p JOIN order_details od ON p.product_id = od.product_id WHERE od.order_id IN (   SELECT DISTINCT order_id FROM order_details WHERE product_id = :productId) AND p.product_id != :productId GROUP BY p.product_id"
      }
    },
    {
