{
  "name": "com.grownited.repository.OrderDetailRepository",
  "module": "JPA",
  "type": "IMPERATIVE",
  "methods": [
    {
      "name": "deleteByOrderId",
      "signature": "public abstract void com.grownited.repository.OrderDetailRepository.deleteByOrderId(java.lang.Integer)",
      "query": {
        "query": "SELECT o FROM OrderDetailEntity o WHERE o.orderId = :orderId"
      }
    },
    {
      "name": "findByOrderId",
      "signature": "public abstract java.util.List<com.grownited.entity.OrderDetailEntity> com.grownited.repository.OrderDetailRepository.findByOrderId(java.lang.Integer)",
      "query": {
        "query": "SELECT o FROM OrderDetailEntity o WHERE o.orderId = :orderId"
      }
    },
    {
      "name": "findByProductId",
      "signature": "public abstract java.util.List<com.grownited.entity.OrderDetailEntity> com.grownited.repository.OrderDetailRepository.findByProductId(java.lang.Integer)",
      "query": {
        "query": "SELECT o FROM OrderDetailEntity o WHERE o.productId = :productId"
      }
    },
    {
      "name": "findOrderDetailsWithProductInfo",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.OrderDetailRepository.findOrderDetailsWithProductInfo(java.lang.Integer)",
      "query": {
        "query": "SELECT od, p.productName, p.mainImageURL FROM OrderDetailEntity od JOIN ProductEntity p ON od.productId = p.productId WHERE od.orderId = :orderId"
      }
    },
    {
      "name": "findTopSellingProducts",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.OrderDetailRepository.findTopSellingProducts(org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT od.productId, SUM(od.quantity) as totalSold FROM OrderDetailEntity od GROUP BY od.productId ORDER BY totalSold DESC"
      }
    },
    {
      "name": "getBestSellingProducts",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.OrderDetailRepository.getBestSellingProducts()",
      "query": {
        "query": "SELECT od.productId, SUM(od.quantity) as totalSold FROM OrderDetailEntity od GROUP BY od.productId ORDER BY totalSold DESC"
      }
    },
    {
      "name": "getMonthlySales",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.OrderDetailRepository.getMonthlySales(int)",
      "query": {
        "query": "SELECT MONTH(od.createdAt), SUM(od.quantity * od.price) FROM OrderDetailEntity od WHERE YEAR(od.createdAt) = :year GROUP BY MONTH(od.createdAt)"
      }
    },
    {
      "name": "getTotalSoldQuantity",
      "signature": "public abstract java.lang.Integer com.grownited.repository.OrderDetailRepository.getTotalSoldQuantity(java.lang.Integer)",
      "query": {
        "query": "SELECT COALESCE(SUM(od.quantity), 0) FROM OrderDetailEntity od WHERE od.productId = :productId"
      }
    },
