    {
      "name": "clearCart",
      "signature": "public abstract void com.grownited.repository.CartRepository.clearCart(java.lang.Integer)",
      "query": {
        "query": "DELETE FROM CartEntity c WHERE c.customerId = :customerId"
      }
    },
    {
      "name": "countByCustomerId",
      "signature": "public abstract java.lang.Long com.grownited.repository.CartRepository.countByCustomerId(java.lang.Integer)",
      "query": {
        "query": "SELECT COUNT(c) FROM CartEntity c WHERE c.customerId = :customerId"
      }
    },
    {
      "name": "deleteByCustomerId",
      "signature": "public abstract void com.grownited.repository.CartRepository.deleteByCustomerId(java.lang.Integer)",
      "query": {
        "query": "SELECT c FROM CartEntity c WHERE c.customerId = :customerId"
      }
    },
    {
      "name": "deleteByCustomerIdAndProductId",
      "signature": "public abstract void com.grownited.repository.CartRepository.deleteByCustomerIdAndProductId(java.lang.Integer,java.lang.Integer)",
      "query": {
        "query": "SELECT c FROM CartEntity c WHERE c.customerId = :customerId AND c.productId = :productId"
      }
    },
    {
      "name": "findByCustomerId",
      "signature": "public abstract java.util.List<com.grownited.entity.CartEntity> com.grownited.repository.CartRepository.findByCustomerId(java.lang.Integer)",
      "query": {
        "query": "SELECT c FROM CartEntity c WHERE c.customerId = :customerId"
      }
    },
    {
      "name": "findByCustomerIdAndProductId",
      "signature": "public abstract java.util.Optional<com.grownited.entity.CartEntity> com.grownited.repository.CartRepository.findByCustomerIdAndProductId(java.lang.Integer,java.lang.Integer)",
      "query": {
        "query": "SELECT c FROM CartEntity c WHERE c.customerId = :customerId AND c.productId = :productId"
      }
    },
    {
      "name": "findCartWithProductDetails",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.CartRepository.findCartWithProductDetails(java.lang.Integer)",
      "query": {
        "query": "SELECT c, p.productName, p.mainImageURL, p.stockQuantity FROM CartEntity c JOIN ProductEntity p ON c.productId = p.productId WHERE c.customerId = :customerId"
      }
    },
    {
      "name": "getCartTotal",
      "signature": "public abstract java.lang.Double com.grownited.repository.CartRepository.getCartTotal(java.lang.Integer)",
      "query": {
        "query": "SELECT COALESCE(SUM(c.price * c.quantity), 0) FROM CartEntity c WHERE c.customerId = :customerId"
      }
    },
