    {
      "name": "findByReturnStatusOrderByRequestedAtAsc",
      "signature": "public abstract org.springframework.data.domain.Page<com.grownited.entity.ReturnRefundEntity> com.grownited.repository.ReturnRefundRepository.findByReturnStatusOrderByRequestedAtAsc(com.grownited.entity.ReturnRefundEntity$ReturnStatus,org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT r FROM ReturnRefundEntity r WHERE r.returnStatus = :status ORDER BY r.requestedAt asc",
        "count-query": "SELECT COUNT(r) FROM ReturnRefundEntity r WHERE r.returnStatus = :status"
      }
    },
    {
      "name": "findPendingReturns",
      "signature": "public abstract java.util.List<com.grownited.entity.ReturnRefundEntity> com.grownited.repository.ReturnRefundRepository.findPendingReturns()",
      "query": {
        "query": "SELECT r FROM ReturnRefundEntity r WHERE r.returnStatus = 'REQUESTED' ORDER BY r.requestedAt ASC"
      }
    },
    {
      "name": "getMonthlyReturnRequests",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.ReturnRefundRepository.getMonthlyReturnRequests(int)",
      "query": {
        "query": "SELECT MONTH(r.requestedAt), COUNT(r) FROM ReturnRefundEntity r WHERE YEAR(r.requestedAt) = :year GROUP BY MONTH(r.requestedAt)"
      }
    },
    {
      "name": "getReturnStatistics",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.ReturnRefundRepository.getReturnStatistics()",
      "query": {
        "query": "SELECT r.returnStatus, COUNT(r) FROM ReturnRefundEntity r GROUP BY r.returnStatus"
      }
    },
