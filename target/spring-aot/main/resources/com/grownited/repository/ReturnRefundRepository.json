    },
    {
      "name": "findByRequestedAtBetween",
      "signature": "public abstract java.util.List<com.grownited.entity.ReturnRefundEntity> com.grownited.repository.ReturnRefundRepository.findByRequestedAtBetween(java.time.LocalDateTime,java.time.LocalDateTime)",
      "query": {
        "query": "SELECT r FROM ReturnRefundEntity r WHERE r.requestedAt BETWEEN :startDate AND :endDate"
      }
    },
    {
