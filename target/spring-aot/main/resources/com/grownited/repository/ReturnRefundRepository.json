    {
      "name": "findByReturnStatus",
      "signature": "public abstract org.springframework.data.domain.Page<com.grownited.entity.ReturnRefundEntity> com.grownited.repository.ReturnRefundRepository.findByReturnStatus(com.grownited.entity.ReturnRefundEntity$ReturnStatus,org.springframework.data.domain.Pageable)",
      "query": {
