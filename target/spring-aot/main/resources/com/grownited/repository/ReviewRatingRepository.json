    {
      "name": "countDistinctCustomers",
      "signature": "public abstract java.lang.Long com.grownited.repository.ReviewRatingRepository.countDistinctCustomers()",
      "query": {
        "query": "SELECT COUNT(DISTINCT r.customerId) FROM ReviewRatingEntity r"
      }
    },
    {
      "name": "countProductsWithReviews",
      "signature": "public abstract java.lang.Long com.grownited.repository.ReviewRatingRepository.countProductsWithReviews()",
      "query": {
        "query": "SELECT COUNT(DISTINCT r.productId) FROM ReviewRatingEntity r"
      }
    },
    {
      "name": "existsByCustomerIdAndProductId",
      "signature": "public abstract boolean com.grownited.repository.ReviewRatingRepository.existsByCustomerIdAndProductId(java.lang.Integer,java.lang.Integer)",
      "query": {
        "query": "SELECT r.reviewId reviewId FROM ReviewRatingEntity r WHERE r.customerId = :customerId AND r.productId = :productId"
      }
    },
    {
      "name": "findByCustomerId",
      "signature": "public abstract java.util.List<com.grownited.entity.ReviewRatingEntity> com.grownited.repository.ReviewRatingRepository.findByCustomerId(java.lang.Integer)",
      "query": {
        "query": "SELECT r FROM ReviewRatingEntity r WHERE r.customerId = :customerId"
      }
    },
    {
      "name": "findByCustomerIdAndProductId",
      "signature": "public abstract java.util.Optional<com.grownited.entity.ReviewRatingEntity> com.grownited.repository.ReviewRatingRepository.findByCustomerIdAndProductId(java.lang.Integer,java.lang.Integer)",
      "query": {
        "query": "SELECT r FROM ReviewRatingEntity r WHERE r.customerId = :customerId AND r.productId = :productId"
      }
    },
    {
      "name": "findByCustomerIdOrderByCreatedAtDesc",
      "signature": "public abstract org.springframework.data.domain.Page<com.grownited.entity.ReviewRatingEntity> com.grownited.repository.ReviewRatingRepository.findByCustomerIdOrderByCreatedAtDesc(java.lang.Integer,org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT r FROM ReviewRatingEntity r WHERE r.customerId = :customerId ORDER BY r.createdAt desc",
        "count-query": "SELECT COUNT(r) FROM ReviewRatingEntity r WHERE r.customerId = :customerId"
      }
    },
    {
      "name": "findByProductIdOrderByCreatedAtDesc",
      "signature": "public abstract java.util.List<com.grownited.entity.ReviewRatingEntity> com.grownited.repository.ReviewRatingRepository.findByProductIdOrderByCreatedAtDesc(java.lang.Integer)",
      "query": {
        "query": "SELECT r FROM ReviewRatingEntity r WHERE r.productId = :productId ORDER BY r.createdAt desc"
      }
    },
    {
      "name": "findByProductIdOrderByCreatedAtDesc",
      "signature": "public abstract org.springframework.data.domain.Page<com.grownited.entity.ReviewRatingEntity> com.grownited.repository.ReviewRatingRepository.findByProductIdOrderByCreatedAtDesc(java.lang.Integer,org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT r FROM ReviewRatingEntity r WHERE r.productId = :productId ORDER BY r.createdAt desc",
        "count-query": "SELECT COUNT(r) FROM ReviewRatingEntity r WHERE r.productId = :productId"
      }
    },
    {
      "name": "findReviewsWithUserDetails",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.ReviewRatingRepository.findReviewsWithUserDetails(java.lang.Integer,org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT r, u.name, u.profilePicURL FROM ReviewRatingEntity r JOIN UserEntity u ON r.customerId = u.userId WHERE r.productId = :productId ORDER BY r.createdAt DESC"
      }
    },
    {
      "name": "findTop10ByOrderByCreatedAtDesc",
      "signature": "public abstract java.util.List<com.grownited.entity.ReviewRatingEntity> com.grownited.repository.ReviewRatingRepository.findTop10ByOrderByCreatedAtDesc()",
      "query": {
        "query": "SELECT r FROM ReviewRatingEntity r ORDER BY r.createdAt desc"
      }
    },
    {
      "name": "getAverageRatingForProduct",
      "signature": "public abstract java.lang.Double com.grownited.repository.ReviewRatingRepository.getAverageRatingForProduct(java.lang.Integer)",
      "query": {
        "query": "SELECT COALESCE(AVG(r.rating), 0) FROM ReviewRatingEntity r WHERE r.productId = :productId"
      }
    },
    {
      "name": "getCustomerReviewSummary",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.ReviewRatingRepository.getCustomerReviewSummary(java.lang.Integer)",
      "query": {
        "query": "SELECT r.customerId, AVG(r.rating), COUNT(r) FROM ReviewRatingEntity r WHERE r.customerId = :customerId GROUP BY r.customerId"
      }
    },
    {
      "name": "getMonthlyReviewStats",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.ReviewRatingRepository.getMonthlyReviewStats(int)",
      "query": {
        "query": "SELECT MONTH(r.createdAt), COUNT(r) FROM ReviewRatingEntity r WHERE YEAR(r.createdAt) = :year GROUP BY MONTH(r.createdAt) ORDER BY MONTH(r.createdAt)"
      }
    },
    {
      "name": "getOverallAverageRating",
      "signature": "public abstract java.lang.Double com.grownited.repository.ReviewRatingRepository.getOverallAverageRating()",
      "query": {
        "query": "SELECT COALESCE(AVG(r.rating), 0) FROM ReviewRatingEntity r"
      }
    },
    {
      "name": "getRatingDistribution",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.ReviewRatingRepository.getRatingDistribution(java.lang.Integer)",
      "query": {
        "query": "SELECT r.rating, COUNT(r) FROM ReviewRatingEntity r WHERE r.productId = :productId GROUP BY r.rating ORDER BY r.rating"
      }
    },
    {
      "name": "getRatingDistributionAll",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.ReviewRatingRepository.getRatingDistributionAll()",
      "query": {
        "query": "SELECT r.rating, COUNT(r) FROM ReviewRatingEntity r GROUP BY r.rating ORDER BY r.rating"
      }
    },
    {
      "name": "getReviewCountForProduct",
      "signature": "public abstract java.lang.Long com.grownited.repository.ReviewRatingRepository.getReviewCountForProduct(java.lang.Integer)",
      "query": {
        "query": "SELECT COUNT(r) FROM ReviewRatingEntity r WHERE r.productId = :productId"
      }
    },
    {
      "name": "getTopRatedProducts",
      "signature": "public abstract java.util.List<java.lang.Object[]> com.grownited.repository.ReviewRatingRepository.getTopRatedProducts(org.springframework.data.domain.Pageable)",
      "query": {
        "query": "SELECT r.productId, AVG(r.rating) as avgRating, COUNT(r) as reviewCount FROM ReviewRatingEntity r GROUP BY r.productId HAVING COUNT(r) >= 3 ORDER BY avgRating DESC, reviewCount DESC"
      }
    },
    {
      "name": "searchReviews",
      "signature": "public abstract java.util.List<com.grownited.entity.ReviewRatingEntity> com.grownited.repository.ReviewRatingRepository.searchReviews(java.lang.Integer,java.lang.String)",
      "query": {
        "query": "SELECT r FROM ReviewRatingEntity r WHERE r.productId = :productId AND LOWER(r.comment) LIKE LOWER(CONCAT('%', :keyword, '%'))"
      }
    },
